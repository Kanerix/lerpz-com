{
    "$schema": "https://json.schemastore.org/tsconfig",
    "display": "Next.js",
    "extends": "./base.json",
    "compilerOptions": {
        "plugins": [{ "name": "next" }],
        "module": "ESNext",
        "moduleResolution": "bundler",
        "jsx": "preserve",
        "allowJs": true,
        "noEmit": true,
        "declaration": false,
        "declarationMap": false,
        "incremental": true
    }
}
