{
    "name": "lerpz-ai",
    "version": "0.0.0",
    "private": true,
    "scripts": {
        "dev": "bun --filter @lerpz/coruscant dev",
        "build": "bun --filter @lerpz/coruscant build",
        "start": "bun --filter @lerpz/coruscant start",
        "check": "bun --filter @lerpz/coruscant check",
        "lint": "bun --filter @lerpz/coruscant lint",
        "format": "bun --filter @lerpz/coruscant format",
        "generate:api": "bun --filter @lerpz/coruscant generate:api"
    },
    "workspaces": [
        "packages/*",
        "svc/coruscant"
    ],
    "engines": {
        "bun": ">=1.4.0"
    },
    "packageManager": "bun@1.4.0-canary.1",
    "devDependencies": {
        "@biomejs/biome": "2.5.0",
        "@lerpz/biome-config": "workspace:*",
        "@lerpz/typescript-config": "workspace:*"
    }
}
