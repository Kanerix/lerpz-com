{
    "name": "lerpz-ai",
    "version": "0.0.0",
    "private": true,
    "scripts": {
        "dev:portal": "bun --filter @lerpz/coruscant dev",
        "build:portal": "bun --filter @lerpz/coruscant build",
        "start:portal": "bun --filter @lerpz/coruscant start",
        "lint:portal": "bun --filter @lerpz/coruscant lint",
        "format:portal": "bun --filter @lerpz/coruscant format",
        "generate:api:portal": "bun --filter @lerpz/coruscant generate:api"
    },
    "workspaces": [
        "packages/*",
        "svc/coruscant"
    ],
    "engines": {
        "node": ">=24"
    },
    "packageManager": "bun@1.4.0-canary.1",
    "devDependencies": {
        "@biomejs/biome": "2.4.16",
        "@lerpz/typescript-config": "workspace:*"
    }
}
